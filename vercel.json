{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/tenant", "destination": "/tenant/index.html" },
    { "source": "/marketing", "destination": "/marketing/index.html" },
    { "source": "/marketing/admin", "destination": "/marketing/admin.html" },
    { "source": "/support", "destination": "/marketing/support.html" }
  ]
}
