# Copy to .env for local builds (never commit .env)
STYLD_SUPABASE_URL=
STYLD_SUPABASE_ANON_KEY=
STYLD_ROOT_DOMAIN=styldd.com
STRIPE_PUBLISHABLE_KEY=

# Supabase Edge Function secrets (set in dashboard or CLI — not in this repo)
